# ============================================================
# Job Autopilot — .gitignore
# ============================================================

# ---------- Secrets (NEVER commit) ----------
.env
.env.local
.env.*.local
*.key
*.pem
*.crt


# ---------- Personal data (NEVER commit) ----------
# All JSON data files contain personal job search activity
data/*.json
data/cover_letters/
data/resume.md
data/resume_scoring.md
data/resume.pdf
data/resume.docx

# Personal config — keep real preferences out of the public repo
config/sources.json
config/filters.json
config/rubric.json

# But keep the folder structure visible in the repo
!data/.gitkeep
!data/cover_letters/.gitkeep

# ---------- Python ----------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Distribution / packaging
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# ---------- Virtual Environments ----------
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# ---------- Testing & Coverage ----------
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# ---------- Type checking & Linting ----------
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/
.pyre/
.pytype/

# ---------- Jupyter / IPython ----------
.ipynb_checkpoints
profile_default/
ipython_config.py

# ---------- IDEs & Editors ----------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# ---------- OS files ----------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ---------- Logs ----------
logs/
*.log
*.log.*

# ---------- Database / temp files ----------
*.db
*.sqlite
*.sqlite3
*.tmp
*.temp
*.bak

# ---------- FastAPI / runtime ----------
.uvicorn.pid