# ============================================================
# Job Autopilot — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your real values.
# .env is gitignored and will never be committed.
#
# Setup:
#   Windows (PowerShell):  Copy-Item .env.example .env
#   macOS / Linux:         cp .env.example .env

# ---------- LLM API Keys ----------
# Required for Phase 2 (job scoring against your resume).
# You only need ONE of these — choose your preferred provider below.

# Get OpenAI key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# Get Anthropic key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# ---------- LLM Configuration ----------
# Which provider to use: "openai" or "anthropic"
LLM_PROVIDER=openai

# Model to use for scoring
# OpenAI options:    gpt-4o-mini  (cheap, fast)   |  gpt-4o     (premium)
# Anthropic options: claude-3-5-haiku-latest      |  claude-3-5-sonnet-latest
LLM_MODEL=gpt-4o-mini

# ---------- Application Paths ----------
# Where data files live (raw_jobs.json, applications.json, etc.)
DATA_DIR=./data

# Where config files live (sources.json, filters.json, etc.)
CONFIG_DIR=./config

# ---------- Logging ----------
# Level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ---------- Dashboard ----------
# Port for the FastAPI dashboard (visit http://localhost:<port>)
DASHBOARD_PORT=8000